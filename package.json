{
  "name": "customer-service",
  "private": true,
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "npm run setup && remix-serve ./build/server/index.js",
    "setup": "prisma generate && prisma migrate deploy",
    "db:migrate": "prisma migrate deploy",
    "test": "node --test app/services/hermes.server.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@remix-run/dev": "^2.17.4",
    "@remix-run/fs-routes": "^2.17.4",
    "@remix-run/node": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "@remix-run/serve": "^2.17.4",
    "@shopify/app-bridge-react": "^4.2.10",
    "@shopify/cli": "^3.94.3",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-app-remix": "^4.2.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "isbot": "^5.1.39",
    "prisma": "^6.19.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@remix-run/eslint-config": "^2.17.4",
    "@remix-run/route-config": "^2.17.4",
    "@shopify/api-codegen-preset": "^2.0.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "author": "YangChao"
}
